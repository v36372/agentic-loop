{
  "name": "agentic-loop",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "oxlint . --ignore-pattern '.agent_sources/**' --ignore-pattern '.pi/**'",
    "format": "oxfmt . '!.**/agent_sources/**' '!.pi/**'",
    "format:check": "oxfmt --check . '!.**/agent_sources/**' '!.pi/**'",
    "check": "pnpm format:check && pnpm lint",
    "test": "pnpm -r --if-present --workspace-concurrency=1 test",
    "typecheck": "tsc -b",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.99",
    "@types/node": "22.15.30",
    "effect": "4.0.0-beta.99",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "5.9.3",
    "ultracite": "7.9.4",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.15.1"
}
